# ==============================================================================
# Multi-Tenant FastAPI System Configuration Blueprint
# ==============================================================================
# Copy this file to '.env' and modify the values for your environment.
# Do not commit actual secrets to version control.

# ------------------------------------------------------------------------------
# Global & Security Settings
# ------------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=replace-with-a-secure-32-character-random-string-for-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Multi-Tenancy Configuration
# ------------------------------------------------------------------------------
# Header used to identify the tenant in incoming HTTP requests
TENANT_HEADER_NAME=X-Tenant-ID
DEFAULT_TENANT_ID=tenant-default
# Comma-separated list of allowed tenant IDs
ALLOWED_TENANTS=tenant-default,tenant-alpha,tenant-beta,tenant-gamma

# ------------------------------------------------------------------------------
# User Service Configuration
# ------------------------------------------------------------------------------
USER_SERVICE_PORT=8001
USER_SERVICE_HOST=0.0.0.0
# SQLite WAL database URL pattern. The system will dynamically inject tenant ID
# if configured for multi-tenant DB isolation, or use a single DB.
# Example for single DB: sqlite+aiosqlite:///./user_service.db
# Example for multi-tenant DB path template: sqlite+aiosqlite:///./user_service_{tenant_id}.db
USER_SERVICE_DB_URL=sqlite+aiosqlite:///./user_service.db
USER_SERVICE_SQLITE_WAL=true

# FastMCP Server Configuration for User Service
USER_SERVICE_FASTMCP_HOST=0.0.0.0
USER_SERVICE_FASTMCP_PORT=8101

# ------------------------------------------------------------------------------
# Payment Service Configuration
# ------------------------------------------------------------------------------
PAYMENT_SERVICE_PORT=8002
PAYMENT_SERVICE_HOST=0.0.0.0
# SQLite WAL database URL pattern.
PAYMENT_SERVICE_DB_URL=sqlite+aiosqlite:///./payment_service.db
PAYMENT_SERVICE_SQLITE_WAL=true

# FastMCP Server Configuration for Payment Service
PAYMENT_SERVICE_FASTMCP_HOST=0.0.0.0
PAYMENT_SERVICE_FASTMCP_PORT=8102

# ------------------------------------------------------------------------------
# Gemini ADK Wrapper & LiteLLM Proxy Configuration
# ------------------------------------------------------------------------------
# Primary Gemini API Key (if using direct Gemini API)
GEMINI_API_KEY=AIzaSyYourActualGeminiAPIKeyHere

# LiteLLM Proxy Configuration (for fallback engine and routing)
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-master-key-change-me

# Model Routing Configuration
PRIMARY_MODEL=gemini/gemini-2.5-flash
FALLBACK_MODEL=gemini/gemini-2.5-pro

# Output Evaluation Loop Settings
MAX_EVALUATION_LOOPS=3
EVALUATION_THRESHOLD=0.85

# ------------------------------------------------------------------------------
# Docker & Infrastructure Settings
# ------------------------------------------------------------------------------
# Docker Compose restart policy (no, always, on-failure, unless-stopped)
DOCKER_RESTART_POLICY=unless-stopped

# Prometheus / Metrics Configuration
METRICS_PORT=9090
PROMETHEUS_ENABLED=true